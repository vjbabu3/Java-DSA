public class Main {
    public static void main(String[] args) {

        int[] arr = {2, 5, 8, 11, 14, 17};

        int even = 0;
        int odd = 0;

        for (int num : arr) {

            if (num % 2 == 0)
                even++;
            else
                odd++;

        }

        System.out.println("Even = " + even);
        System.out.println("Odd = " + odd);

    }
}
